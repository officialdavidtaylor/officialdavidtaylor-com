# Compose-level settings for the dedicated cloudflared host template.
# Keep these paths relative to the directory where you run docker compose.

CLOUDFLARED_IMAGE=cloudflare/cloudflared:2026.2.1
CLOUDFLARED_METRICS_PORT=2000
CLOUDFLARED_METRICS_BIND=0.0.0.0:2000

# Local files/directories mounted into the container
CLOUDFLARED_CONFIG_PATH=./config.yml
CLOUDFLARED_CREDENTIALS_PATH=./credentials
