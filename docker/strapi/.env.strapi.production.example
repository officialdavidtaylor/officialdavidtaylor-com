# Strapi runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=1337
PUBLIC_URL=https://cms.example.com
TRUST_PROXY=true

# JSON array allowlist for browser origins calling the Strapi API
# Example: ["https://officialdavidtaylor.com","https://www.officialdavidtaylor.com"]
CORS_ORIGIN=["https://officialdavidtaylor.com"]
CORS_CREDENTIALS=true

# Required Strapi secrets (persist these)
APP_KEYS=replace-with-random-1,replace-with-random-2,replace-with-random-3,replace-with-random-4
API_TOKEN_SALT=replace-with-random-value
ADMIN_JWT_SECRET=replace-with-random-value
TRANSFER_TOKEN_SALT=replace-with-random-value
ENCRYPTION_KEY=replace-with-random-value
JWT_SECRET=replace-with-random-value

# Remote Postgres (Option A: URL)
# DATABASE_URL=postgres://strapi:replace-me@pg.lan:5432/strapi

# Remote Postgres (Option B: explicit fields)
DATABASE_CLIENT=postgres
DATABASE_HOST=pg.lan
DATABASE_PORT=5432
DATABASE_NAME=strapi
DATABASE_USERNAME=strapi
DATABASE_PASSWORD=replace-me
DATABASE_SCHEMA=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT=60000

# Postgres TLS (enable if configured on the DB host)
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true
# DATABASE_SSL_CA=
# DATABASE_SSL_CERT=
# DATABASE_SSL_KEY=

# Remote MinIO (S3-compatible uploads)
# Configured by apps/strapi-cms/config/plugins.ts (provider: aws-s3, endpoint: MinIO)
S3_ENDPOINT=http://minio.lan:9000
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-me
S3_BUCKET=strapi-uploads
S3_REGION=us-east-1
S3_FORCE_PATH_STYLE=true

# Optional provider settings
# S3_ROOT_PATH=portfolio
# S3_ACL=public-read
S3_USE_SIGNED_URLS=false
S3_SIGNED_URL_EXPIRES=900

# Strongly recommended when media is exposed through Cloudflare/reverse proxy.
# Also used to allow media previews in the Strapi admin CSP.
S3_PUBLIC_URL=https://media.example.com

# Optional but recommended: automatically clear and rewarm the web app's
# records cache after record or artist changes.
RECORDS_INVALIDATE_URL=https://officialdavidtaylor.com/api/invalidate/records
RECORDS_INVALIDATE_SECRET=replace-with-the-web-invalidation-secret

# Optional only if using the embedded cloudflared service in docker/strapi/docker-compose.production.yml
# CF_TUNNEL_TOKEN_CMS=replace-me
