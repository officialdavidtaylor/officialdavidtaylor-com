# Strapi runtime
NODE_ENV=production
HOST=0.0.0.0
PORT=1337
PUBLIC_URL=https://cms.officialdavidtaylor.com
PUBLIC_URL_CMS=https://cms.officialdavidtaylor.com
TRUST_PROXY=true
CORS_ORIGIN=https://officialdavidtaylor.com,https://www.officialdavidtaylor.com
CORS_CREDENTIALS=true

# Local admin / metrics bindings on the Mac Mini host
WEB_LOCAL_PORT=4321
STRAPI_LOCAL_PORT=1337
MINIO_CONSOLE_PORT=9001
CLOUDFLARED_METRICS_PORT=2000
CLOUDFLARED_METRICS_BIND=0.0.0.0:2000
CLOUDFLARED_IMAGE=cloudflare/cloudflared:2026.2.1

# Prebuilt application images pulled from your personal registry
WEB_IMAGE=registry.emfsoft.com/officialdavidtaylor/web:0.1.0
STRAPI_IMAGE=registry.emfsoft.com/officialdavidtaylor/strapi-cms:0.1.0

# Postgres container
POSTGRES_DB=strapi
POSTGRES_USER=strapi
POSTGRES_PASSWORD=replace-with-strong-password

# Required Strapi secrets
APP_KEYS=replace-with-random-1,replace-with-random-2,replace-with-random-3,replace-with-random-4
API_TOKEN_SALT=replace-with-random-value
ADMIN_JWT_SECRET=replace-with-random-value
TRANSFER_TOKEN_SALT=replace-with-random-value
ENCRYPTION_KEY=replace-with-random-value
JWT_SECRET=replace-with-random-value

# Strapi database settings
DATABASE_CLIENT=postgres
DATABASE_SCHEMA=public
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10
DATABASE_CONNECTION_TIMEOUT=60000
DATABASE_SSL=false
DATABASE_SSL_REJECT_UNAUTHORIZED=true

# MinIO / S3-compatible object storage
MINIO_ROOT_USER=replace-me
MINIO_ROOT_PASSWORD=replace-with-strong-password
MINIO_BUCKET_PUBLIC=true
S3_BUCKET=strapi-uploads
S3_REGION=us-east-1
# Use the same values as the MinIO credentials unless you create a dedicated MinIO user/access key.
S3_ACCESS_KEY_ID=replace-me
S3_SECRET_ACCESS_KEY=replace-with-strong-password
S3_FORCE_PATH_STYLE=true
S3_PUBLIC_URL=https://media.officialdavidtaylor.com
S3_USE_SIGNED_URLS=false
S3_SIGNED_URL_EXPIRES=900
# S3_ROOT_PATH=portfolio
# S3_ACL=public-read
