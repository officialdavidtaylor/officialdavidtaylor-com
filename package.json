{
  "name": "officialdavidtaylor-com",
  "type": "module",
  "version": "0.0.1",
  "private": true,
  "packageManager": "yarn@4.5.0",
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "astro dev --host",
    "dev:cms": "yarn workspace strapi-cms dev",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down",
    "build": "astro build",
    "start": "node ./dist/server/entry.mjs",
    "preview": "astro preview --host",
    "format": "prettier . --write",
    "records:import": "node scripts/import-records-to-strapi.mjs",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/node": "^9.5.0",
    "astro": "^5.17.5",
    "gray-matter": "^4.0.3",
    "lucide": "^0.469.0",
    "qs": "^6.14.0"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.15",
    "@tailwindcss/vite": "^4.1.13",
    "@types/qs": "^6.14.0",
    "prettier": "^3.4.2",
    "prettier-plugin-astro": "^0.14.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "tailwindcss": "^4.1.13",
    "typescript": "^5.7.2"
  }
}
