---
export const prerender = false;

import type { LiveDataEntry } from 'astro';
import { getLiveCollection } from 'astro:content';

import type { RecordData } from 'lib/server/records';
import { isWithinDays } from 'utils/isWithinDays';
import Root from 'layouts/Root.astro';

type RecordsState = 'ready' | 'empty' | 'error';

let records: Array<LiveDataEntry<RecordData>> = [];
let recordsState: RecordsState = 'ready';

try {
  const recordArray = await getLiveCollection('records');

  if (recordArray.error || !recordArray.entries) {
    throw (
      recordArray.error ?? new Error('Record collection returned no entries')
    );
  }

  if (recordArray.cacheHint) {
    Astro.cache.set(recordArray.cacheHint);
  }

  recordArray.entries.forEach((record) => {
    Astro.cache.set(record);
  });
  Astro.cache.set({ maxAge: 60 * 5, swr: 60 });

  records = recordArray.entries;

  if (records.length === 0) {
    recordsState = 'empty';
  }
} catch (error) {
  recordsState = 'error';
  console.error('Unable to load record collection', error);
}
---

<Root title="My Record Collection">
  <div class="mx-auto max-w-4xl pt-[20%] font-serif">
    <h1 class="pb-14 text-5xl md:text-center">My Record Collection</h1>
    <div class="pb-4 text-xl">
      <p>My partner gifted me a record player for a recent birthday.</p>
      <br />
      <p>
        Since then I've been building my collection one LP at a time, with much
        help from beloved family and friends.
      </p>
      <br />
      <p>This is the collection thus far:</p>
    </div>
  </div>
  <div
    class="-mx-4 mt-8 mb-4 flex max-w-4xl flex-col gap-2 bg-neutral-100 p-2 py-3 font-sans sm:mx-auto sm:gap-2 sm:rounded-xl sm:p-2"
  >
    {
      (recordsState === 'error' || recordsState === 'empty') && (
        <div class="p-6 text-center text-xl text-neutral-600">
          <p>The collection is taking a little nap right now.</p>
          <br />
          <p>Please check back in a bit.</p>
        </div>
      )
    }
    {
      recordsState === 'ready' &&
        records.map((record) => {
          const isNewAddition = isWithinDays(record.data.receivedOn, 14);
          return (
            <div
              class={[
                'relative flex items-center gap-4 rounded-lg border-2 p-2 select-none',
                isNewAddition ? 'border-neutral-400' : 'border-transparent',
              ].join(' ')}
            >
              {isNewAddition && (
                <p class="absolute -top-2 right-0 left-0 mx-auto h-min w-32 bg-neutral-100 p-1 text-center leading-2 text-neutral-600">
                  recent addition!
                </p>
              )}
              <img
                src={record.data.coverUrl}
                alt=""
                role="presentation"
                class="max-w-20 rounded-sm shadow-sm"
              />
              <div class="h-full">
                <p class="text-2xl leading-6">{record.data.title}</p>
                <p class="font-serif text-lg text-neutral-400">
                  {record.data.artistName}
                </p>
              </div>
            </div>
          );
        })
    }
  </div>
</Root>
